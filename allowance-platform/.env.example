# 공통
NODE_ENV=development

# 백엔드 서버
PORT=4000
CLIENT_URL=http://localhost:5173
SESSION_SECRET=change-this-session-secret
JWT_SECRET=change-this-jwt-secret
ENCRYPTION_KEY=change-this-aes256-key

# DB: PostgreSQL 사용 시 DATABASE_URL 설정
# 예시: postgresql://postgres:postgres@localhost:5432/allowance_platform
DATABASE_URL=

# 로컬 개발용(SQLite)
SQLITE_PATH=./database.sqlite

# 프론트엔드(Vite)
VITE_API_URL=http://localhost:4000/api
